{
  "name": "@pico-investimentos/api",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "engines": {
    "node": "22.x"
  },
  "packageManager": "npm@10.9.2",
  "scripts": {
    "dev": "TMPDIR=/tmp tsx watch scripts/dev.ts",
    "build": "tsc -p tsconfig.build.json",
    "start": "node dist/scripts/dev.js",
    "typecheck": "tsc --noEmit --pretty false",
    "lint": "eslint . --max-warnings=0",
    "test": "TMPDIR=/tmp vitest run",
    "test:watch": "TMPDIR=/tmp vitest",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:check": "drizzle-kit check",
    "db:studio": "drizzle-kit studio",
    "db:seed-user": "TMPDIR=/tmp tsx scripts/seed-user.ts"
  },
  "dependencies": {
    "@hono/node-server": "^2.0.8",
    "drizzle-orm": "^0.45.2",
    "hono": "^4.12.28",
    "postgres": "^3.4.9",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/node": "^26.1.1",
    "drizzle-kit": "^0.31.10",
    "eslint": "^10.6.0",
    "globals": "^17.7.0",
    "tsx": "^4.23.0",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.63.0",
    "vitest": "^4.1.10"
  }
}
