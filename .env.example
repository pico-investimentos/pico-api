NODE_ENV=development
PORT=3000
APP_ORIGINS=http://localhost:5173,http://localhost:5174
LOG_LEVEL=info

# Canonical names (preferred)
DATABASE_URL=postgresql://postgres:postgres@127.0.0.1:6543/postgres
DATABASE_MIGRATION_URL=postgresql://postgres:postgres@127.0.0.1:5432/postgres

# Supabase / Vercel Marketplace aliases (accepted as fallback)
# SUPABASE_POSTGRES_URL=
# SUPABASE_POSTGRES_URL_NON_POOLING=

# Session
SESSION_COOKIE_NAME=pico_session
SESSION_TTL_HOURS=168
# Obrigatório em produção; use pelo menos 32 caracteres aleatórios.
# RATE_LIMIT_KEY_SECRET=

# -----------------------------------------------------------------------------
# B3 — escolha UM ambiente por deployment (nunca misture pacotes)
# Local: pasta em api/.secrets/b3/{certification|production}/ (gitignored)
# Vercel: use B3_CLIENT_ID + B3_CLIENT_SECRET + B3_MTLS_*_PEM_BASE64 (sem pasta)
# -----------------------------------------------------------------------------

# --- Certificação (dev local / staging) ---
B3_ENVIRONMENT=certification
# Host API (default se omitido): https://apib3i-cert.b3.com.br:2443
# B3_API_BASE_URL=https://apib3i-cert.b3.com.br:2443
B3_OPT_IN_URL=https://b3investidorcer.b2clogin.com/...
B3_OPT_IN_ALLOWED_HOSTS=b3investidorcer.b2clogin.com
B3_SECRETS_DIR=.secrets/b3/certification

# Smoke: npm run b3:smoke -- --cpf=###########

# Timeout HTTP B3 (default 30000). Fail-closed: sem secrets a API não sobe em
# production; em development use B3_ALLOW_INMEMORY=1 só para testes locais.
# B3_HTTP_TIMEOUT_MS=30000
# B3_ALLOW_INMEMORY=0

# Crons de Posição D-1 (Vercel → GET /api/v1/internal/b3/daily-position-sync e
# GET /api/v1/internal/b3/process-position-syncs)
# CRON_SECRET=

# --- Produção (somente deploy production; pacote separado) ---
# B3_ENVIRONMENT=production
# B3_API_BASE_URL=https://investidor.b3.com.br:2443
# B3_OPT_IN_URL=https://b3investidor.b2clogin.com/...
# B3_OPT_IN_ALLOWED_HOSTS=b3investidor.b2clogin.com
# B3_SECRETS_DIR=.secrets/b3/production

# --- Vercel (substituem B3_SECRETS_DIR; PEM em Base64 de uma linha) ---
# B3_CLIENT_ID=
# B3_CLIENT_SECRET=
# B3_MTLS_CERT_PEM_BASE64=
# B3_MTLS_KEY_PEM_BASE64=
# B3_P12_PASSWORD=
